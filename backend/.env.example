# PostgreSQL — Neon, Supabase, Railway, RDS, etc.
DATABASE_URL="postgresql://user:password@host:5432/datafuse?schema=public"

# JWT — use a long random string in production
JWT_SECRET="change-me-to-a-very-long-random-string"
JWT_EXPIRES_IN="7d"

# Server
PORT=4000
NODE_ENV=production

# CORS — frontend origin(s), comma separated. Use * in dev only.
CORS_ORIGIN="http://localhost:8080"

# Seed admin (créé par `npm run seed`)
SEED_ADMIN_EMAIL="admin@datafuse.app"
SEED_ADMIN_PASSWORD="ChangeMe123!"
